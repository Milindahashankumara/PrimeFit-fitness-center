# Root workspace hygiene

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files (never commit secrets)
.env
.env.*
!.env.example

# Build/cache artifacts
.dist/
**/.next/
**/dist/
**/build/
**/coverage/

# Dependencies
**/node_modules/

# TypeScript / framework
**/*.tsbuildinfo

# Keep nested repositories out of the root repo if present
**/.git/
